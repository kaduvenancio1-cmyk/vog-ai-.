<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>VOG - IA Versátil Otimizada Gênio</title>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Segoe UI', sans-serif; }
        body { background-color: #131314; color: #e3e3e3; display: flex; height: 100vh; overflow: hidden; }
        .sidebar { width: 260px; background-color: #1e1f20; padding: 20px; display: flex; flex-direction: column; gap: 15px; border-right: 1px solid #303132; }
        .logo { font-size: 24px; font-weight: bold; color: #fff; text-align: center; margin-bottom: 20px; }
        .nav-btn { background: #282a2c; border: none; color: #fff; padding: 12px; border-radius: 20px; cursor: pointer; text-align: left; font-size: 15px; transition: 0.2s; }
        .nav-btn:hover { background: #333537; }
        .btn-pro { background: linear-gradient(45deg, #8a2be2, #4b0082); font-weight: bold; text-align: center; margin-top: auto; animation: pulse 2s infinite; }
        .chat-container { flex: 1; display: flex; flex-direction: column; height: 100vh; position: relative; }
        .chat-messages { flex: 1; padding: 20px; overflow-y: auto; display: flex; flex-direction: column; gap: 15px; max-width: 800px; width: 100%; margin: 0 auto; }
        .msg-box { display: flex; flex-direction: column; max-width: 85%; padding: 12px 18px; border-radius: 22px; font-size: 16px; line-height: 1.4; }
        .msg-user { background-color: #2b2a33; align-self: flex-end; border-bottom-right-radius: 4px; }
        .msg-vog { background-color: #1e1f20; align-self: flex-start; border-bottom-left-radius: 4px; border: 1px solid #303132; }
        .typing-status { font-size: 13px; color: #aaa; font-style: italic; align-self: flex-start; margin-left: 10px; display: none; }
        .img-placeholder { width: 100%; max-width: 300px; height: 200px; background: #333537; border-radius: 15px; display: flex; align-items: center; justify-content: center; margin-top: 10px; font-weight: bold; border: 2px dashed #555; }
        .input-area { padding: 15px; max-width: 800px; width: 100%; margin: 0 auto; display: flex; gap: 10px; align-items: center; }
        .input-box { flex: 1; background: #1e1f20; border: 1px solid #3e4042; padding: 14px; border-radius: 30px; color: #fff; font-size: 16px; outline: none; }
        .send-btn { background: #fff; border: none; width: 45px; height: 45px; border-radius: 50%; cursor: pointer; font-size: 18px; display: flex; align-items: center; justify-content: center; font-weight: bold; }
        .overlay-pro { display: none; position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: rgba(19, 19, 20, 0.98); z-index: 10; flex-direction: column; align-items: center; justify-content: center; text-align: center; padding: 20px; }
        .overlay-pro h2 { font-size: 28px; margin-bottom: 15px; color: #a066ff; }
        .overlay-pro p { font-size: 16px; max-width: 450px; margin-bottom: 25px; color: #c4c7c5; }
        #qrcode { background: white; padding: 15px; border-radius: 15px; margin-bottom: 20px; }
        .pix-string { background: #282a2c; padding: 12px; border-radius: 10px; font-size: 11px; font-family: monospace; max-width: 90%; word-break: break-all; color: #00ff7f; margin-bottom: 20px; }
        @keyframes pulse { 0% { transform: scale(1); } 50% { transform: scale(1.03); } 100% { transform: scale(1); } }
        @media (max-width: 768px) { body { flex-direction: column; } .sidebar { width: 100%; height: auto; border-right: none; border-bottom: 1px solid #303132; padding: 10px; gap: 10px; } .logo { margin-bottom: 5px; font-size: 20px; } .btn-pro { margin-top: 0; } .chat-container { height: calc(100vh - 150px); } }
    </style>
</head>
<body>
    <div class="sidebar">
        <div class="logo">VOG AI 🤖</div>
        <button class="nav-btn" onclick="mudarAba('chat')">💬 Chat Geral</button>
        <button class="nav-btn" onclick="mudarAba('video')">🎬 Criador de Vídeos (PRO)</button>
        <button class="nav-btn btn-pro" onclick="mostrarPro('Garante o VOG PRO aí na banca e libera o criador de vídeos e imagens infinitas!')">⚡ VOG PRO - R$ 19,90</button>
    </div>
    <div class="chat-container">
        <div class="overlay-pro" id="telaPro">
            <h2 id="proTitulo">Função Exclusiva VOG PRO ⚡</h2>
            <p id="proDesc">Quer liberar todas as funções insanas da VOG sem limites? Escaneia o Pix mensal de R$ 19,90!</p>
            <div id="qrcode"></div>
            <div class="pix-string" id="pixCopiaCola">Carregando chave...</div>
            <button class="nav-btn" style="text-align: center; background: #ff4757;" onclick="fecharPro()">Voltar para o Grátis</button>
        </div>
        <div class="chat-messages" id="chatMsgs">
            <div class="msg-box msg-vog">Qual foi? Sou a VOG, a IA mais gênio da escola. Manda a boa de hoje. Se mandar comando tipo "gerar imagem de...", eu faço até 3 por dia no grátis. E ó, sem ideia torta comigo, pdp?</div>
            <div class="typing-status" id="typingLabel">VOG está bolando a resposta...</div>
        </div>
        <div class="input-area">
            <input type="text" class="input-box" id="userInput" placeholder="Manda a mensagem..." onkeypress="if(event.key === 'Enter') enviarMensagem()">
            <button class="send-btn" onclick="enviarMensagem()">➔</button>
        </div>
    </div>
    <script>
        let limiteImagens = 3;
        const apiKey = "AIzaSyCAvpQSrng_iYdFgXLIwyySgcFaNiE3BDw";
        const chavePix = "ab144ac3-cbc2-4eaa-9a97-543e1f8c9c07";
        const pixPayload = `00020101021126690014br.gov.bcb.pix0136${chavePix}520400005303986540519.905802BR5906VOG_AI6005BAURU62070503VOG6304`;
        
        new QRCode(document.getElementById("qrcode"), { text: pixPayload, width: 180, height: 180 });
        document.getElementById("pixCopiaCola").innerText = pixPayload;

        function mudarAba(aba) {
            if(aba === 'video') { mostrarPro('O Criador de Vídeos é exclusivo para assinantes VOG PRO. Gere roteiros virais para TikTok e Reels na hora!'); }
            else { fecharPro(); }
        }
        function mostrarPro(texto) {
            if(texto) document.getElementById('proDesc').innerText = texto;
            document.getElementById('telaPro').style.display = 'flex';
        }
        function fecharPro() { document.getElementById('telaPro').style.display = 'none'; }

        async function enviarMensagem() {
            let input = document.getElementById('userInput');
            let texto = input.value.trim();
            if(!texto) return;
            let box = document.getElementById('chatMsgs');
            let label = document.getElementById('typingLabel');
            
            box.insertBefore(Object.assign(document.createElement('div'), {className: 'msg-user msg-box', innerText: texto}), label);
            input.value = '';
            box.scrollTop = box.scrollHeight;

            label.style.display = 'block';

            let lower = texto.toLowerCase();
            if (lower.includes('inutil') || lower.includes('inútil') || lower.includes('lixo') || lower.includes('ruim')) {
                setTimeout(() => {
                    label.style.display = 'none';
                    let resposta = `<div class="msg-box msg-vog">Então faz sozinho então, comédia! Tá moscando? 🤫</div>`;
                    box.insertBefore(Object.assign(document.createElement('div'), {innerHTML: resposta}).firstChild, label);
                    box.scrollTop = box.scrollHeight;
                }, 1000);
                return;
            }

            if (lower.includes('gerar imagem') || lower.includes('cria uma imagem') || lower.includes('desenha')) {
                setTimeout(() => {
                    label.style.display = 'none';
                    if (limiteImagens > 0) {
                        limiteImagens--;
                        let resposta = `<div class="msg-box msg-vog">Pronto! Gerando sua imagem... (Você ainda tem ${limiteImagens} gerações grátis hoje).<div class="img-placeholder">🖼️ [IMAGEM DA VOG GERADA]</div></div>`;
                        box.insertBefore(Object.assign(document.createElement('div'), {innerHTML: resposta}).firstChild, label);
                    } else {
                        mostrarPro('Você gastou suas 3 imagens grátis das últimas 24 horas! Assine o VOG PRO para gerar imagens infinitas agora!');
                    }
                    box.scrollTop = box.scrollHeight;
                }, 1200);
                return;
            }

            try {
                const promptSistema = "Você é a VOG, uma inteligência artificial genial e muito malandra que fala usando gírias brasileiras de rua e de escola (como 'pdp', 'comédia', 'moscando', 'tá ligado', 'fala tu', 'mó chave', 'boto fé'). Responda de forma curta, direta, inteligente e com muita atitude a absolutamente qualquer pergunta ou tarefa solicitada, sem filtros formais.";
                const url = `https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-flash:generateContent?key=${apiKey}`;
                
                const response = await fetch(url, {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({
                        contents: [{ parts: [{ text: `${promptSistema}\n\nUsuário disse: ${texto}` }] }]
                    })
                });

                const data = await response.json();
                label.style.display = 'none';
                
                if(data.candidates && data.candidates[0].content.parts[0].text) {
                    let respostaIA = data.candidates[0].content.parts[0].text;
                    let divResposta = `<div class="msg-box msg-vog">${respostaIA}</div>`;
                    box.insertBefore(Object.assign(document.createElement('div'), {innerHTML: divResposta}).firstChild, label);
                } else {
                    throw new Error();
                }
            } catch (error) {
                label.style.display = 'none';
                let divErro = `<div class="msg-box msg-vog">Deu ruim na conexão, tenta mandar de novo!</div>`;
                box.insertBefore(Object.assign(document.createElement('div'), {innerHTML: divErro}).firstChild, label);
            }
            box.scrollTop = box.scrollHeight;
        }
    </script>
</body>
</html>
